# Runtime
NODE_ENV=development

# Auth
AUTH_REQUIRED=true
OPERATOR_ID=user_internal_operator
OPERATOR_EMAIL=operator@xbot.local
OPERATOR_ROLE=admin
OPERATOR_PASSWORD=ChangeMe!123
# Optional bcrypt hash alternative to plain password
OPERATOR_PASSWORD_HASH=
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# Core infra
POSTGRES_URL=postgresql://xbot:xbot@localhost:5432/xbot
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=xbot-audit

# Security
JWT_SECRET=change_me
ENCRYPTION_KEY=change_me_32_chars_minimum

# AI providers
CLAUDE_API_KEY=
OPENAI_API_KEY=
OPENCLAW_ENDPOINT=http://127.0.0.1:11434

# Trading
EXECUTION_MODE=paper
POLYMARKET_ALLOW_LIVE=false
POLYMARKET_API_BASE=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLYMARKET_ORDER_ENDPOINT=/order
POLYMARKET_CANCEL_ENDPOINT=/order/cancel

# Risk defaults
RISK_PRESET=conservative
AUTO_GATE_WINDOW_DAYS=30
